# ==============================================================================
# Finanzas Familia — configuracion (copia este archivo como .env y edita)
# ==============================================================================
# Entorno: development | production
ENV=development

# Base de datos (SQLite en local; en VPS puedes seguir con SQLite o pasar a MariaDB)
DATABASE_URL=sqlite:///./finanzas.db

# Secreto de sesion. En prod genera uno: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-me

# URL base de la app (puerto 8088 para no chocar con el 99520, que usa 8080)
APP_PORT=8088
APP_URL=http://localhost:8088

# Moneda y zona horaria
CURRENCY=CLP
TIMEZONE=America/Santiago

# === ASISTENTE IA (DeepSeek) ===
# Sin key, el bot usa un parser heuristico local (funciona igual para anotar gastos).
# Consigue tu key en https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# === TELEGRAM (bot oficial, reemplaza al puente WhatsApp) ===
# Creá el bot con @BotFather en Telegram: /newbot
# Ponele nombre "Finanzas Familia" y username @FinanzasFamiliaBot.
# Pegá el token que te da. Sin token, el bot no funciona.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Opcional: secreto para verificar que el webhook viene de Telegram (si no se define, usa SECRET_KEY).
TELEGRAM_WEBHOOK_SECRET=

# === PUENTE WHATSAPP (whatsapp-web.js, conexión por QR) ===
# En desuso desde que se migró a Telegram. Se conserva por retrocompatibilidad.
WHATSAPP_BRIDGE_URL=http://localhost:8099
WHATSAPP_BRIDGE_TOKEN=bridge-dev-token

# === LOGIN CON GOOGLE (OAuth 2.0) ===
# Crea un "OAuth client ID" tipo Web en https://console.cloud.google.com/apis/credentials
# Redirect URI autorizado a registrar:  <APP_URL>/auth/google/callback
# Vacios = el dashboard queda abierto en modo local (sin login).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Opcional: restringe a un dominio (ej: miempresa.cl). Vacio = cualquier Gmail.
GOOGLE_HOSTED_DOMAIN=
# Integracion con Google Calendar (agenda recordatorios). Requiere habilitar
# "Google Calendar API" en el proyecto de Google Cloud. false = desactivada.
GOOGLE_CALENDAR=true

# === SUPER ADMIN ===
# Contraseña del panel /admin (crear familias, perfiles, aprobar accesos).
# Vacía y sin Google configurado = panel abierto (solo para desarrollo local).
ADMIN_PASSWORD=
# Tu correo de Google: al entrar con el, eres super admin automatico (sin password).
SUPER_ADMIN_EMAIL=
